# ========== STUDY & EARN BOT CONFIG ==========
# Yeh file .env.example hai — copy karke .env banao aur values bharo

# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_id_here
BOT_USERNAME=YourBotUsername

# Server
SERVER_URL=your-app.up.railway.app

# Public Channel ID (jo channel pe notify jaata hai)
PUBLIC_CHANNEL=-1000000000000

# Ad Link
AD_LINK=https://your-ad-link.com

# ========== CATEGORY CHANNEL IDs ==========
CHANNEL_PHYSICS=-1000000000001
CHANNEL_CHEMISTRY=-1000000000002
CHANNEL_MATHS=-1000000000003
CHANNEL_MIX=-1000000000004
CHANNEL_ZOOLOGY=-1000000000005
CHANNEL_ASTROLOGY=-1000000000006
CHANNEL_SNAP=-1000000000007
CHANNEL_RUSSIAN=-1000000000008
